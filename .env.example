GEMINI_API_KEY=
JWT_SECRET=evalix-pro-secret-2026
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NODE_ENV=production
# Firebase Service Account JSON string for non-GCP deployments (like Vercel)
# Create a Service Account in Firebase Console -> Project Settings -> Service Accounts
FIREBASE_SERVICE_ACCOUNT=
# Optional: specify if using a named Firestore database
FIRESTORE_DATABASE_ID=

# Client-side Firebase Config (Prefix with VITE_ for Vite to expose them)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
