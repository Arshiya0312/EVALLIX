{
  "entities": {
    "Faculty": {
      "title": "Faculty",
      "description": "Faculty user profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "photo": { "type": "string" }
      },
      "required": ["uid", "email", "name"]
    },
    "Class": {
      "title": "Class",
      "description": "Academic class node",
      "type": "object",
      "properties": {
        "faculty_id": { "type": "string" },
        "name": { "type": "string" },
        "semester": { "type": "string" },
        "year": { "type": "string" },
        "section": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["faculty_id", "name"]
    },
    "Subject": {
      "title": "Subject",
      "description": "Subject within a class",
      "type": "object",
      "properties": {
        "class_id": { "type": "string" },
        "name": { "type": "string" },
        "textbook_url": { "type": "string" },
        "notes_url": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["class_id", "name"]
    },
    "Student": {
      "title": "Student",
      "description": "Student registered in a class",
      "type": "object",
      "properties": {
        "class_id": { "type": "string" },
        "roll_no": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["class_id", "roll_no"]
    },
    "Rubric": {
      "title": "Rubric",
      "description": "Evaluation rubric",
      "type": "object",
      "properties": {
        "subject_id": { "type": "string" },
        "faculty_id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string" },
        "criteria_json": { "type": "string" }
      },
      "required": ["subject_id", "faculty_id", "name"]
    },
    "Evaluation": {
      "title": "Evaluation",
      "description": "Result of an AI evaluation",
      "type": "object",
      "properties": {
        "student_id": { "type": "string" },
        "subject_id": { "type": "string" },
        "total_marks": { "type": "number" },
        "obtained_marks": { "type": "number" },
        "result_json": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["student_id", "subject_id", "total_marks", "obtained_marks"]
    }
  },
  "firestore": {
    "/faculty/{facultyId}": {
      "schema": "Faculty",
      "description": "Top-level faculty documents"
    },
    "/faculty/{facultyId}/classes/{classId}": {
      "schema": "Class",
      "description": "Classes belonging to a facultyMember"
    },
    "/faculty/{facultyId}/subjects/{subjectId}": {
      "schema": "Subject",
      "description": "Subjects belonging to a facultyMember"
    },
    "/faculty/{facultyId}/students/{studentId}": {
      "schema": "Student",
      "description": "Students belonging to a facultyMember"
    },
    "/faculty/{facultyId}/rubrics/{rubricId}": {
      "schema": "Rubric",
      "description": "Rubrics belonging to a facultyMember"
    },
    "/faculty/{facultyId}/evaluations/{evaluationId}": {
      "schema": "Evaluation",
      "description": "Evaluations belonging to a facultyMember"
    }
  }
}
