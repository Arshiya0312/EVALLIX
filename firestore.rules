rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(facultyId) {
      return isSignedIn() && request.auth.uid == facultyId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Faculty Profile
    match /faculty/{facultyId} {
      allow read, write: if isOwner(facultyId);
      
      // Classes
      match /classes/{classId} {
        allow read, write: if isOwner(facultyId) && isValidId(classId);
      }

      // Subjects
      match /subjects/{subjectId} {
        allow read, write: if isOwner(facultyId) && isValidId(subjectId);
      }

      // Students
      match /students/{studentId} {
        allow read, write: if isOwner(facultyId) && isValidId(studentId);
      }

      // Rubrics
      match /rubrics/{rubricId} {
        allow read, write: if isOwner(facultyId) && isValidId(rubricId);
      }

      // Evaluations
      match /evaluations/{evaluationId} {
        allow read, write: if isOwner(facultyId) && isValidId(evaluationId);
      }
    }
  }
}
