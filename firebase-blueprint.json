{
  "entities": {
    "Faculty": {
      "title": "Faculty",
      "description": "Educational staff member profile",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "email": { "type": "string" },
        "name": { "type": "string" },
        "photo": { "type": "string" }
      },
      "required": ["uid", "email", "name"]
    },
    "Class": {
      "title": "Class",
      "description": "A cohort of students",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "semester": { "type": "string" },
        "year": { "type": "string" },
        "section": { "type": "string" },
        "faculty_id": { "type": "string" }
      },
      "required": ["name", "faculty_id"]
    },
    "Subject": {
      "title": "Subject",
      "description": "Academic course within a class",
      "type": "object",
      "properties": {
        "class_id": { "type": "string" },
        "name": { "type": "string" },
        "textbook_url": { "type": "string" },
        "notes_url": { "type": "string" }
      },
      "required": ["class_id", "name"]
    },
    "Student": {
      "title": "Student",
      "description": "Individual student record",
      "type": "object",
      "properties": {
        "class_id": { "type": "string" },
        "roll_no": { "type": "string" },
        "name": { "type": "string" }
      },
      "required": ["class_id", "roll_no", "name"]
    },
    "Evaluation": {
      "title": "Evaluation",
      "description": "Result of an AI answer sheet assessment",
      "type": "object",
      "properties": {
        "student_id": { "type": "string" },
        "subject_id": { "type": "string" },
        "total_marks": { "type": "number" },
        "obtained_marks": { "type": "number" },
        "result_json": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["student_id", "subject_id", "total_marks", "obtained_marks"]
    },
    "Rubric": {
      "title": "Rubric",
      "description": "Scoring criteria for an assessment",
      "type": "object",
      "properties": {
        "subject_id": { "type": "string" },
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["unit", "test", "exam"] },
        "criteria_json": { "type": "string" },
        "faculty_id": { "type": "string" }
      },
      "required": ["subject_id", "name", "criteria_json", "faculty_id"]
    }
  },
  "firestore": {
    "/faculty/{facultyId}": {
      "schema": "Faculty",
      "description": "Faculty profiles"
    },
    "/faculty/{facultyId}/classes/{classId}": {
      "schema": "Class",
      "description": "Classes managed by a faculty"
    },
    "/faculty/{facultyId}/subjects/{subjectId}": {
      "schema": "Subject",
      "description": "Subjects managed by a faculty"
    },
    "/faculty/{facultyId}/students/{studentId}": {
      "schema": "Student",
      "description": "Students managed by a faculty"
    },
    "/faculty/{facultyId}/rubrics/{rubricId}": {
      "schema": "Rubric",
      "description": "Faculty rubrics"
    },
    "/faculty/{facultyId}/evaluations/{evaluationId}": {
      "schema": "Evaluation",
      "description": "Evaluations performed by the faculty"
    }
  }
}
